{
	"name": "spring-office",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"f": "bun scripts/fuzzy-bun-run.ts",
		"dev": "bun run docker:check && portless",
		"dev:app": "bun --bun vite dev",
		"dev:host": "bun run docker:check && bun scripts/check-port.ts && bun --bun vite dev --host",
		"dev:emails": "email dev --dir src/lib/server/email",
		"update:env": "bun scripts/pull-env.ts",
		"update:infra": "bun scripts/log-infra.ts",
		"update:agents": "bun scripts/build-agents-rules.ts",
		"docker:start": "docker compose up -d && bun run docker:check",
		"docker:stop": "docker compose stop",
		"docker:reset": "docker compose down -v",
		"docker:check": "bun scripts/check-docker.ts",
		"url:redis": "bun scripts/copy-docker-url.ts redis",
		"db:gen": "bunx --bun drizzle-kit generate",
		"db:migrate": "bunx --bun drizzle-kit migrate",
		"db:push": "bunx --bun drizzle-kit push",
		"db:reset": "bun scripts/reset-db.ts",
		"db:seed": "bun db/seed/index.ts",
		"db:upgrade": "bunx --bun drizzle-kit up",
		"db:studio": "bunx --bun drizzle-kit studio",
		"check": "bun scripts/check-all.ts",
		"check:prettier": "prettier --write .",
		"check:eslint": "eslint . --cache --concurrency auto",
		"check:svelte": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:review": "cubic review --base origin/next",
		"preview": "bun run build && bunx --bun vite preview",
		"build": "bunx --bun vite build",
		"start": "bun run ./build"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@react-email/ui": "^6.5.0",
		"@socketsecurity/bun-security-scanner": "^1.1.2",
		"@sveltejs/kit": "^2.61.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/bun": "^1.3.14",
		"@types/node": "^25.9.1",
		"@types/react": "^19.2.15",
		"drizzle-kit": "^1.0.0-rc.4-ca0f029",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.18.0",
		"globals": "^17.6.0",
		"portless": "^0.13.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.0.1",
		"prettier-plugin-tailwindcss": "0.8.0",
		"svelte": "^5.55.9",
		"svelte-adapter-bun": "^1.0.1",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.0",
		"vite": "^8.0.14"
	},
	"dependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@fontsource/open-runde": "^5.2.1",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^1.16.0",
		"@opensky/remotes": "^0.0.3",
		"@opensky/seo": "^1.1.0",
		"@opensky/style": "^0.1.0",
		"@tabler/icons-svelte": "^3.44.0",
		"@toolwind/anchors": "^1.0.10",
		"@toolwind/corner-shape": "^0.0.8-3",
		"@upstash/ratelimit": "2.0.8",
		"@web-kits/audio": "^0.1.0",
		"bits-ui": "^2.18.1",
		"croner": "^10.0.1",
		"drizzle-orm": "^1.0.0-rc.4-5d5b77c",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"react-email": "^6.5.0",
		"resend": "^6.12.4",
		"runed": "^0.37.1",
		"torph": "^0.0.9",
		"ua-parser-js": "^2.0.10",
		"valibot": "^1.4.1"
	},
	"patchedDependencies": {
		"@sveltejs/kit@2.58.0": "patches/@sveltejs%2Fkit@2.58.0.patch"
	}
}

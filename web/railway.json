{
	"$schema": "https://railway.com/railway.schema.json",
	"build": {
		"watchPatterns": ["web/**"],
		"builder": "RAILPACK",
		"buildCommand": "mkdir -p /data && bun run build"
	},
	"deploy": {
		"startCommand": "bun run db:migrate && bun run start",
		"restartPolicyType": "ALWAYS",
		"restartPolicyMaxRetries": 5,
		"healthcheckPath": "/health"
	}
}
